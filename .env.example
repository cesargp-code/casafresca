# Supabase Configuration
# Get these values from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side key used by /api/push-subscriptions to store browser push subscriptions
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Web Push VAPID public key used by the browser Push API
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Same public key plus private key for the Supabase monitor function
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:you@example.com
